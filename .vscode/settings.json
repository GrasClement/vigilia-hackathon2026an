{
    // =============================================
    // CONFIGURATION VSCode - TEST_PACKAGE
    // =============================================

    // 1. INTERPRÉTEUR PYTHON
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "python.terminal.activateEnvironment": true,
    "python.terminal.activateEnvInCurrentTerminal": true,
    "python.venvPath": "${workspaceFolder}",
    "python.envFile": "${workspaceFolder}/.env",

    // 2. RUFF
    "ruff.path": ["${workspaceFolder}/.venv/Scripts/ruff.exe"],
    "ruff.interpreter": ["${workspaceFolder}/.venv/Scripts/python.exe"],

    // 3. PYTHON (formatage + linting)
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        }
    },

    // 4. JUPYTER
    "[jupyter]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true
    },
    "jupyter.notebookFileRoot": "${workspaceFolder}",
    "jupyter.jupyterServerType": "local",

    // 5. PROXY
    "http.proxy": "http://proxy-rie.ccomptes.fr:8001",
    "http.proxyStrictSSL": false,

    // 6. TERMINAL
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "path": "pwsh.exe",
            "args": []
        },
        "Command Prompt": {
            "path": "cmd.exe",
            "args": []
        },
        "Git Bash": {
            "path": "C:\\Workspace\\Scoop\\apps\\git\\current\\bin\\bash.exe",
            "args": ["--login", "-i"]
        }
    },
    "terminal.integrated.env.windows": {
        "HTTP_PROXY": "http://proxy-rie.ccomptes.fr:8001",
        "HTTPS_PROXY": "http://proxy-rie.ccomptes.fr:8001",
        "NO_PROXY": ".ccomptes.fr,localhost,127.0.0.1",
        "no_proxy": ".ccomptes.fr,localhost,127.0.0.1",
        "UV_CACHE_DIR": "C:\\Workspace\\uv_cache",
        "UV_PYTHON_INSTALL_DIR": "C:\\Workspace\\uv_python"
    },

    // 7. UV
    "uv.pythonPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "uv.cacheDir": "C:\\Workspace\\uv_cache",

    // 8. POLICES
    "editor.fontFamily": "'Consolas', 'Courier New', monospace",
    "editor.fontSize": 14,
    "editor.fontLigatures": false,
    "terminal.integrated.fontFamily": "'Consolas', 'Courier New', monospace",
    "terminal.integrated.fontSize": 13,

    // 9. INTERFACE
    "workbench.colorTheme": "Dark+",
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter-notebook"
    },
    // 10. EXTENSIONS
    "extensions.ignoreRecommendations": false,
    "extensions.autoUpdate": true
}