[
    {
        "key": "ctrl+alt+p u",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "uv pip install ${selectedText}${newLine}"
        },
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+alt+p r",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "uv run ${selectedText}${newLine}"
        },
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+alt+p g",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "git ${selectedText}${newLine}"
        },
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+alt+p j",
        "command": "jupyter.runCurrentCell",
        "when": "editorTextFocus && jupyter.ownsEditor"
    },
        {
        "key": "ctrl+shift+m",
        "command": "change-case.toToggleCase",
        "when": "editorTextFocus || jupyter.ownsEditor"
    }
]
